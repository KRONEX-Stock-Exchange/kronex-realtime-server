generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum OrderType {
  LIMIT // 지정가
  MARKET // 시장가
}

enum TradingType {
  BUY
  SELL
  EDIT
  CANCEL
}

enum CursorType {
  EVENT
}

enum OrderStatus {
  RECEIVED // 접수됨 (DB 기록 완료, 큐 적재 전)
  OPEN // 큐 적재 성공 (엔진으로 전달된 활성 주문)
  FILLED // 완전 체결되어 종료
  CANCELED // 주문 취소
  REPLACED // 정정 주문으로 대체되어 닫힘
  REJECTED // 거부됨
}

enum OrderRejectReason {
  INVALID_ORDER // 잘못된 주문
  INSUFFICIENT_BALANCE // 예수금 부족
  INSUFFICIENT_STOCK // 보유 수량 부족
  PRICE_OUT_OF_LIMIT // 상/하한가 벗어남
  STOCK_NOT_TRADABLE // 거래정지/상장폐지 종목
  ALREADY_PROCESSED // 이미 처리(체결/취소)된 주문
}

enum Role {
  ADMIN
  USER
}

enum StockStatus {
  PENDING // 상장 전
  LISTED // 상장
  SUSPENDED // 거래 정지
  DELISTED // 상장 폐지
}

enum AccountStatus {
  PENDING // 대기
  ACTIVE // 활성
}

enum CandleType {
  ONE_MINUTE      @map("1m")
  FIVE_MINUTES    @map("5m")
  FIFTEEN_MINUTES @map("15m")
  THIRTY_MINUTES  @map("30m")
  ONE_HOUR        @map("1h")
  ONE_DAY         @map("1d")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(20)
  password  String   @db.VarChar(60)
  email     String   @unique @db.VarChar(50)
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @map("created_at")

  accounts      Account[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id          Int    @id @default(autoincrement())
  userId      Int    @map("user_id")
  hashedToken String @map("hashed_token")

  user User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

// 일반 계좌
model Account {
  id               Int           @id @default(autoincrement())
  userId           Int           @map("user_id")
  accountNumber    Int           @unique @map("account_number")
  balance          BigInt        @db.UnsignedBigInt
  availableBalance BigInt        @map("available_balance") @db.UnsignedBigInt
  status           AccountStatus @default(PENDING)
  publishedAt      DateTime?     @map("published_at") // 큐 적재 성공 시각 (null = 미발행)
  createdAt        DateTime      @default(now()) @map("created_at")

  user       User        @relation(fields: [userId], references: [id])
  userStocks UserStock[]
  orders     Order[]

  @@index([publishedAt]) // 릴레이가 미발행 계좌 스캔
  @@map("accounts")
}

// 주식 정보
model Stock {
  id           Int         @id @default(autoincrement())
  name         String      @unique @db.VarChar(30)
  price        BigInt      @db.UnsignedBigInt
  listingPrice BigInt      @db.UnsignedBigInt @map("listing_price")
  status       StockStatus @default(PENDING)
  publishedAt DateTime?   @map("published_at") // 큐 적재 성공 시각 (null = 미발행)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime?   @updatedAt @map("updated_at")

  userStocks UserStock[]
  orders     Order[]
  trades     Trade[]
  candles    Candle[]

  @@index([publishedAt]) // 릴레이가 미발행 주식 스캔
  @@map("stocks")
}

// 캔들 (차트 봉 데이터)
model Candle {
  stockId    Int      @map("stock_id")
  candleTime DateTime @map("candle_time")
  type       CandleType
  open       BigInt   @db.UnsignedBigInt
  high       BigInt   @db.UnsignedBigInt
  low        BigInt   @db.UnsignedBigInt
  close      BigInt   @db.UnsignedBigInt
  volume     BigInt   @db.UnsignedBigInt

  stock Stock @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@id([stockId, candleTime, type])
  @@index([stockId, type, candleTime])
  @@map("candles")
}


// 주식 계좌(보유 종목) 정보
model UserStock {
  accountId         Int    @map("account_id")
  stockId           Int    @map("stock_id")
  quantity          BigInt @db.UnsignedBigInt
  availableQuantity BigInt @map("available_quantity") @db.UnsignedBigInt
  average           BigInt @db.UnsignedBigInt
  totalBuyAmount    BigInt @map("total_buy_amount") @db.UnsignedBigInt

  account Account @relation(fields: [accountId], references: [id])
  stock   Stock   @relation(fields: [stockId], references: [id])

  @@id([accountId, stockId])
  @@map("user_stocks")
}

// 주문
model Order {
  id             BigInt             @id @default(autoincrement())
  targetId       BigInt?            @map("target_id") // 정정/취소 대상 원주문 (신규 주문이면 null)
  accountId      Int                @map("account_id")
  stockId        Int                @map("stock_id")
  price          BigInt             @db.UnsignedBigInt
  quantity       BigInt             @db.UnsignedBigInt
  filledQuantity BigInt             @map("filled_quantity") @db.UnsignedBigInt
  orderType      OrderType          @map("order_type")
  status         OrderStatus        @default(RECEIVED)
  rejectReason   OrderRejectReason? @map("reject_reason") // status=REJECTED일 때만
  tradingType    TradingType        @map("trading_type")
  publishedAt    DateTime?          @map("published_at") // 큐 적재 성공 시각 (null = 미발행)
  createdAt      DateTime           @default(now()) @map("created_at")

  account Account @relation(fields: [accountId], references: [id])
  stock   Stock   @relation(fields: [stockId], references: [id])

  target     Order?  @relation("OrderTarget", fields: [targetId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  targetedBy Order[] @relation("OrderTarget")

  tradesAsMaker Trade[] @relation("TradeMaker")
  tradesAsTaker Trade[] @relation("TradeTaker")

  @@index([publishedAt]) // 릴레이가 미발행 주문 스캔
  @@index([stockId, status, tradingType, price])
  @@index([accountId, status, createdAt])
  @@index([accountId, createdAt])
  @@map("orders")
}

// 체결 내역
model Trade {
  id           BigInt   @id @default(autoincrement())
  stockId      Int      @map("stock_id")
  price        BigInt   @db.UnsignedBigInt // 체결가
  quantity     BigInt   @db.UnsignedBigInt
  makerOrderId BigInt   @map("maker_order_id") // 기존에 존재한 주문
  takerOrderId BigInt   @map("taker_order_id") // 체결을 발생시킨 주문
  matchedAt    DateTime @default(now()) @map("matched_at")

  stock      Stock @relation(fields: [stockId], references: [id])
  makerOrder Order @relation("TradeMaker", fields: [makerOrderId], references: [id])
  takerOrder Order @relation("TradeTaker", fields: [takerOrderId], references: [id])

  @@index([stockId, matchedAt])
  @@map("trades")
}

// 엔진 상태 스냅샷
model Snapshot {
  id            BigInt   @id @default(autoincrement())
  state         Bytes    @map("state") @db.LongBlob // 직렬화된 엔진 전체 상태
  inputWalIndex BigInt   @map("input_wal_index") @db.UnsignedBigInt
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("snapshots")
}

// 커서
model Cursor {
  type  CursorType @id
  index BigInt

  @@map("cursors")
}
